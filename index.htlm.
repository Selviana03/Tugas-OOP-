        <h3>Jawaban Soal No. 3:</h3>
        <p>Membuat Class <b>Hewan</b> dengan atribut <b>nama</b> dan metode <b>bersuara()</b>.</p>

        <pre>
<span class="cmt">// Definisi Class Hewan dalam Dart</span>
<span class="kwd">class</span> <span class="typ">Hewan</span> {
  <span class="cmt">// Atribut</span>
  <span class="typ">String</span> nama;

  <span class="cmt">// Konstruktor</span>
  <span class="typ">Hewan</span>(<span class="kwd">this</span>.nama);

  <span class="cmt">// Metode</span>
  <span class="kwd">void</span> <span class="met">bersuara</span>() {
    print(<span class="str">"$nama sedang bersuara: Rauuurrr!"</span>);
  }
}

<span class="kwd">void</span> <span class="met">main</span>() {
  <span class="cmt">// Membuat Objek dari Class Hewan</span>
  <span class="kwd">var</span> kucing = <span class="typ">Hewan</span>(<span class="str">"Kucing"</span>);
  
  <span class="cmt">// Mengakses Atribut dan Metode</span>
  print(<span class="str">"Nama Hewan: ${kucing.nama}"</span>);
  kucing.bersuara();
}</pre>
